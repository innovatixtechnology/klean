{
  "name": "klean",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "dev:secure": "next dev --experimental-https",
    "start": "node .next/standalone/server.js",
    "preview": "next build && next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format --write",
    "prepare": "husky",
    "db:generate": "drizzle-kit generate --config=src/config/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=src/config/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=src/config/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=src/config/drizzle.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.47.0",
    "@tanstack/react-form": "^1.28.6",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "nextjs-toploader": "^3.9.17",
    "postgres": "^3.4.8",
    "posthog-js": "^1.364.7",
    "radix-ui": "^1.4.3",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
